# ==============================================================================
# Agentic Career Counseling Companion — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ==============================================================================

# --- IBM watsonx.ai Credentials ---
# Obtain from IBM Cloud → IAM → API Keys
IBM_API_KEY=your_ibm_api_key_here

# Obtain from watsonx.ai project → Manage → General → Project ID
IBM_PROJECT_ID=your_watsonx_project_id_here

# Regional endpoint for your IBM Cloud account
# Options: https://us-south.ml.cloud.ibm.com
#          https://eu-de.ml.cloud.ibm.com
#          https://jp-tok.ml.cloud.ibm.com
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- IBM Watson Speech-To-Text Credentials (STT Fallback) ---
# Obtain from IBM Cloud → Watson Speech to Text service → Credentials
WATSON_STT_API_KEY=your_watson_stt_api_key_here
WATSON_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# --- Flask Application ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_flask_secret_key_here

# Set to "development" locally, "production" on Cloud Foundry
FLASK_ENV=development

# --- Application Settings ---
# Default session timeout in seconds (1 hour)
SESSION_LIFETIME_SECONDS=3600

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- CORS & Sessions (Production / Cross-Origin Deployment) ---
# The URL of your deployed frontend (e.g. Netlify/Vercel) to allow CORS requests.
# Defaults to http://localhost:3000 if unset.
# FRONTEND_URL=https://your-frontend.vercel.app

# Set to 'None' for cross-origin deployments (requires secure cookie secure=True).
# Defaults to 'Lax' if unset.
# SESSION_COOKIE_SAMESITE=None

